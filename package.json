{
	"name": "sychev-lab-mcp-server",
	"version": "1.0.0",
	"description": "MCP Server for Sychev Lab - Products, Articles, Tutorials, and Commerce",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"sychev-lab-mcp": "dist/index.js"
	},
	"files": [
		"dist/**/*",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"start": "node dist/index.js",
		"start:http": "node dist/server-http.js",
		"start:http:legacy": "node dist/index.js --http",
		"inspector": "npx @modelcontextprotocol/inspector dist/index.js",
		"lint": "eslint src/**/*.ts",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"sychev-lab",
		"ecommerce",
		"stl",
		"3d-printing"
	],
	"author": "Anton Sychev",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git@github.com:Sychev-Lab/sychev-lab-mcp-server.git"
	},
	"bugs": {
		"url": "https://github.com/Sychev-Lab/sychev-lab-mcp-server/issues"
	},
	"homepage": "https://github.com/Sychev-Lab/sychev-lab-mcp-server#readme",
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.0",
		"zod": "^3.23.8",
		"zod-to-json-schema": "^3.23.5"
	},
	"devDependencies": {
		"@types/node": "^20.14.0",
		"typescript": "^5.4.5"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
